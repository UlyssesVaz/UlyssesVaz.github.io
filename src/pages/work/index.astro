---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { WORK } from "@consts"

const collection = (await getCollection("work")).filter(item => item.data.type !== "education")
collection.sort((a, b) => new Date(b.data.dateStart).getTime() - new Date(a.data.dateStart).getTime())

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render()
    return { ...item, Content }
  })
)

function formatWorkDate(input: Date | string) {
  if (typeof input === "string") return input
  const month = input.toLocaleDateString("en-US", { month: "short" })
  const year = new Date(input).getFullYear()
  return `${month} ${year}`
}
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <TopLayout>
    <h1 class="animate page-heading">
      Work & Experience
    </h1>
  </TopLayout>
  <BottomLayout>
    <ul>
      {work.map((entry) => {
        const isCommunity = entry.data.type === "community"
        const isEducation = entry.data.type === "education"
        return (
          <li class:list={[
            "animate border-b border-black/10 dark:border-white/25 mt-4 py-8 first-of-type:mt-0 first-of-type:pt-0 last-of-type:border-none",
            (isCommunity || isEducation) && "opacity-60"
          ]}>
            <div class="flex items-center gap-2 mb-3">
              <div class="text-sm uppercase opacity-75">
                {formatWorkDate(entry.data.dateStart)} — {formatWorkDate(entry.data.dateEnd)}
              </div>
              {isCommunity && (
                <span class="text-xs px-2 py-0.5 rounded-full border border-black/20 dark:border-white/20">
                  Community
                </span>
              )}
              {isEducation && (
                <span class="text-xs px-2 py-0.5 rounded-full border border-black/20 dark:border-white/20">
                  Education
                </span>
              )}
            </div>
            <div class="text-black dark:text-white font-semibold">
              {entry.data.url
                ? <a href={entry.data.url} target="_blank" class="hover:underline">{entry.data.company}</a>
                : entry.data.company
              }
            </div>
            <div class="text-sm font-semibold opacity-75">
              {entry.data.role}
            </div>
            <article class="prose dark:prose-invert mt-2">
              <entry.Content />
            </article>
          </li>
        )
      })}
    </ul>
  </BottomLayout>
</PageLayout>
