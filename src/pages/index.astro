---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import { SITE, SOCIALS } from "@consts"
import TwinklingStars from "@components/TwinklingStars.astro"
import MeteorShower from "@components/MeteorShower.astro"

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)
---

<PageLayout title={SITE.TITLE} description={SITE.DESCRIPTION}>

  <!-- Dark Theme: Stars -->
  <div class='absolute inset-0 bg-black hidden dark:block'>
    <div id='stars1' class='fixed inset-0'></div>
    <div id='stars2' class='fixed inset-0'></div>
    <div id='stars3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Meteors -->
  <div id="galaxy" class="fixed inset-0">
    <div class="hidden dark:block">
      <TwinklingStars/>
      <MeteorShower/>
    </div>
  </div>

  <script is:inline src="/js/bg.js"></script>

  <!-- HERO -->
  <section class="relative h-screen w-full">
    <div class="animate absolute h-full w-full flex items-center justify-center">
      <div class="w-full max-w-screen-lg mx-auto px-8 flex flex-col md:flex-row items-center gap-10 md:gap-16">

        <!-- Photo -->
        <div class="flex-shrink-0 order-1 md:order-2">
          <img
            src="/images/profile.jpg"
            alt="Ulysses Vazquez-Perez"
            class="w-40 h-40 md:w-56 md:h-56 rounded-full object-cover object-top border border-black/10 dark:border-white/10"
          />
        </div>

        <!-- Text -->
        <div class="order-2 md:order-1 text-center md:text-left">
          <p class="animated text-xs uppercase tracking-widest opacity-50 mb-3">
            Seattle · Business · Technology
          </p>
          <h1 class="animated text-4xl md:text-5xl lg:text-6xl font-bold text-black dark:text-white leading-tight">
            Ulysses<br/>Vazquez-Perez
          </h1>
          <p class="animated mt-4 text-base md:text-lg opacity-70 max-w-md">
            Business is the Vehicle of Innovation,<br/>Technology is the Driver of Innovation.
          </p>
          <p class="animated mt-2 text-xs opacity-40 tracking-wide max-w-md">
            BA · Accounting & Information Systems · UW Foster School of Business · 2025
          </p>
          <div class="animated flex flex-wrap gap-2 mt-5 justify-center md:justify-start">
            {["Builder", "Strategist", "Community", "Seattle"].map(tag => (
              <span class="px-3 py-1 text-xs rounded-full border border-black/20 dark:border-white/20 text-black/60 dark:text-white/60">
                {tag}
              </span>
            ))}
          </div>
          <div id="ctaButtons" class="animated flex flex-wrap gap-4 justify-center md:justify-start mt-8">
            <a href='/work' class='py-2 px-5 rounded-full text-sm bg-black dark:bg-white text-white dark:text-black hover:opacity-75 blend'>
              View my work
            </a>
            <a href='/blog' class='py-2 px-5 rounded-full text-sm border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend'>
              Read my writing
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="relative bg-white dark:bg-black">
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">

      <!-- About Section -->
      <section class="animate">
        <article>
          <p>UW Foster BA in Accounting and Information Systems. Working across the intersection of technology, business and community to integrate the needs of people, the possibilities of technology, and the requirements for business success.</p>
          <p>2x Deloitte Internship · Technology Consulting Association · Walking Club Ambassador</p>
        </article>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <h2 class="font-semibold text-black dark:text-white">
              Recent projects
            </h2>
            <a href="/projects" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                All projects
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Blog Preview Section -->
      {posts.length > 0 && (
        <section class="animate">
          <div class="space-y-4">
            <div class="flex justify-between">
              <h2 class="font-semibold text-black dark:text-white">
                Recent writing
              </h2>
              <a href="/blog" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                  All posts
                </span>
              </a>
            </div>
            <ul class="space-y-4">
              {posts.map((post) => (
                <li>
                  <ArrowCard entry={post} />
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      <!-- FAQ Section -->
      <section class="animate">
        <div class="space-y-6">
          <h2 class="font-semibold text-black dark:text-white">A few things people ask</h2>
          <div class="space-y-5">
            {[
              {
                q: "Is a business degree worth it for a tech career?",
                a: "Depends what you want to do. I studied Accounting and Information Systems at UW Foster. Accounting teaches you how businesses actually work. IS teaches you how systems solve those problems. If you want to build technology for organizations rather than just build technology, that combination is hard to beat."
              },
              {
                q: "How do you build high agency in your career?",
                a: "Learn to solve your problems and then learn to communicate them. In doing you realize what is important to you."
              },
              {
                q: "Do you need a CS degree to work in tech?",
                a: "No. Since tech is just a movement and ever changing there is a need for every contributor in the system. If you want to learn how to build tech, it can be helpful as there are so many world systems that tech uses to be built out, but if you are able to use world systems to understand how tech is built that can be powerful too."
              },
            ].map(({ q, a }) => (
              <div>
                <h3 class="font-medium text-black dark:text-white">{q}</h3>
                <p class="mt-1 opacity-70 text-sm">{a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <h2 class="font-semibold text-black dark:text-white">
            Let's Connect
          </h2>
          <p>
            Reach out via email or find me on social.
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                  <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                    {social.TEXT}
                  </span>
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

    </div>
  </div>
</PageLayout>
